<!-- 
    DJ
    By: Sanskar Thapa
-->

<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, height=device-height, initial-scale=1.0">
        <link rel='stylesheet' type='text/css' media='screen' href='css/dj.css'>
        <link rel='stylesheet' type='text/css' media='screen' href='css/group12.css'>

        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHg4CGR2D7kSs0v4LLanw2qksYuRlEzO+tcaEPQogQ0KaoGN26/zrn20ImR1DfuLWnOo7aBA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
        <title>Radio App</title>
    </head>

    <body>
            <%- include('../partials/header') %>

            <div class="container">
                <div class="leftside">
                    <div class="time-slot">
                        <div class="title" >
                            <span onmouseover="alert('Pick a time slot to view the records played at that time.')">TIME SLOT</span>
                        </div>
                        <div class="slot-body">
                            <ul id="time-list">
                                <li>
                                    12am - 1am
                                </li>
                                <li>
                                    1am - 2am
                                </li>
                                <li>
                                    2am - 3am
                                </li>
                                <li>
                                    3am - 4am
                                </li>
                                <li>
                                    4am - 5am
                                </li>
                                <li>
                                    5am - 6am
                                </li>
                                <li>
                                    6am - 7am
                                </li>
                                <li>
                                    7am - 8am
                                </li>
                                <li>
                                    8am - 9am
                                </li>
                                <li>
                                    9am - 10am
                                </li>
                                <li>
                                    10am - 11am
                                </li>
                                <li>
                                    11am - 12pm
                                </li>
                                <li>
                                    12pm - 1pm
                                </li>
                                <li>
                                    1pm - 2pm
                                </li>
                                <li>
                                    2pm - 3pm
                                </li>
                                <li>
                                    3pm - 4pm
                                </li>
                                <li>
                                    4pm - 5pm
                                </li>
                                <li>
                                    5pm - 6pm
                                </li>
                                <li>
                                    6pm - 7pm
                                </li>
                                <li>
                                    7pm - 8pm
                                </li>
                                <li>
                                    8pm - 9pm
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="record-slot">
                        <div class="title">
                            <span onclick="alert('Check out the records and add them to the current library using + button')"> RECORD</span>
                        </div>
                        <div class="slot-body">
                            <ul id="rec-ul">
                            </ul>
                        </div>

                    </div>
                </div>
                <div class="rightside">
                    <div class="music-playlist">
                        <div class="title">
                            <span>MY MUSIC</span>
                        </div>
                        <div class="music-slot">
                            <table id="music-table">
                                <tr>
                                    <th>Title</th>
                                    <th>Album</th>
                                    <th>Artist</th>
                                </tr>
                                <tr>
                                    <td>Song 1</td>
                                    <td>Album A</td>
                                    <td>Artist 1</td>
                                </tr>
                                <tr>
                                    <td>Song 2</td>
                                    <td>Album B</td>
                                    <td>Artist 2</td>
                                </tr>
                                <tr>
                                    <td>Song 3</td>
                                    <td>Album C</td>
                                    <td>Artist 3</td>
                                </tr>
                            </table>  
    
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../partials/footer') %>

            <audio id="audio-player" class="audio-controls" controls src="audio/Oliver Tree - Star.mp3"></audio>
        <script src="js/dj.js"></script>

    </body>
</html>
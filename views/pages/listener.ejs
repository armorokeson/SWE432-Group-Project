<!-- 
    Listener
    By: William Okeson
-->

<!DOCTYPE html>
<html>

<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>Listener</title>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <link rel='stylesheet' type='text/css' media='screen' href='css/listener.css'>
    <link rel='stylesheet' type='text/css' media='screen' href='css/group12.css'>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha512-Fo3rlrZj/k7ujTnHg4CGR2D7kSs0v4LLanw2qksYuRlEzO+tcaEPQogQ0KaoGN26/zrn20ImR1DfuLWnOo7aBA==" crossorigin="anonymous" referrerpolicy="no-referrer"
    />
</head>

<body>

    <%- include('../partials/header') %>

        <div class="container">

            <div class="grid-container">
                <!-- Album Cover & Lyrics -->
                <div class="grid-item">

                    <!-- Album Cover -->
                    <div class="section album-cover">
                        <img class="album-cover-image" src="images/alone_in_a_crowd.jpeg" />
                        <div class="song-title">
                            <div>Star</div>
                            <div>by Oliver Tree</div>
                        </div>
                        <i id="add-song" class="plus-icon fa-solid fa-plus"></i>
                    </div>

                    <!-- Lyrics -->
                    <div class="section lyrics">
                        <p>
                            [Pre-Chorus]<br /> When I watch you from a distance<br /> You really start to glisten<br /> When I see you are approachin'<br /> All I know is<br />
                        </p>

                        <p>
                            [Chorus]<br /> Baby, you're a star<br /> So keep on goin'<br /> You made it this far<br /> You shine bright and you show it<br /> Baby, you're a star<br />
                        </p>

                        <p>[Verse 1]<br /> And no one can stop you<br /> The world is yours, so do what you want to<br /> You will find that if you try<br /> No mountain is too hard to climb<br />
                        </p>
                    </div>

                </div>

                <!-- My Music -->
               <%- include('../partials/my_music', { songs: songs }) %>

                <!-- Upcoming DJ's & Queue -->
                <div class="grid-item">

                    <!-- Upcoming DJ's -->
                    <div class="section upcoming-djs">
                        <h3>Upcoming DJ's</h3>
                        <div class="list">
                            <ul>
                                <li>
                                    <span>DJ 1</span>
                                    <span style="margin: 1rem">Time 1</span>
                                </li>
                                <li>
                                    <span>DJ 2</span>
                                    <span style="margin: 1rem">Time 2</span>
                                </li>
                                <li>
                                    <span>DJ 3</span>
                                    <span style="margin: 1rem">Time 3</span>
                                </li>
                                <li>
                                    <span>DJ 4</span>
                                    <span style="margin: 1rem">Time 4</span>
                                </li>
                                <li>
                                    <span>DJ 5</span>
                                    <span style="margin: 1rem">Time 5</span>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Queue -->
                    <div class="section queue">
                        <h3>Queue</h3>
                        <table class="table">
                            <tr>
                                <th>Name</th>
                                <th>Artist</th>
                            </tr>
                            <tr>
                                <td>Song 1</td>
                                <td>Artist 1</td>
                            </tr>
                            <tr>
                                <td>Song 2</td>
                                <td>Artist 2</td>
                            </tr>
                            <tr>
                                <td>Song 3</td>
                                <td>Artist 3</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="review-form">
            <form name="reviewForm" onsubmit="return validateReview(event)">
                <p style="color: white;">Leave a Review</p>
                <input type="text" name="review-text" />
                <button type="submit">Submit</button>
            </form>
        </div>

        <%- include('../partials/footer') %>

            <audio id="audio-player" class="audio-controls" controls src="audio/Oliver Tree - Star.mp3"></audio>

</body>
<script src='js/listener.js'></script>
<script src="js/menu.js"></script>

</html>